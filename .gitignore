# Git Ignore Rules for Netbox Lab

# Docker
.dockerignore
docker-compose.override.yml
Docker/.env
Docker/Data/
Docker/logs/

# Legacy runtime locations (kept ignored if recreated)
Code/Data/
Code/logs/

# Logs
logs/**/*.log
logs/**/*.txt
*.log

# Data and Database
Data/postgres/*
Data/netbox/media/*
Data/volumes/*
Data/inputs/*.csv
!Data/inputs/*.template.csv
!Data/**/.gitkeep

# Environment variables
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
venv/
env/
.venv/

# Ansible
*.retry
.ansible-cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
.DS_Store

# Secrets
secrets/
*.pem
*.key

# Temporary files
tmp/
temp/
*.tmp

# Backup files
*.bak
*.backup
